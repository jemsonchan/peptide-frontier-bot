# Copy to .env for local testing (never commit .env). In production these are GitHub Actions secrets.

# ---- Writer LLM (pick one; Gemini is default & cheapest) ----
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini

# ---- X (Twitter) — @peptidefrontier ----
# Create at developer.x.com -> Project/App -> Keys & tokens.
# App permissions MUST be "Read and write". Regenerate access token AFTER setting write.
PF_X_API_KEY=
PF_X_API_SECRET=
PF_X_ACCESS_TOKEN=
PF_X_ACCESS_SECRET=

# ---- Optional: Nostr (free, on-brand) ----
# NOSTR_NSEC=
